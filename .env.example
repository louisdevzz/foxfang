# ==========================================
# FoxFang Gateway / Railway Setup
# ==========================================

# Required for /setup web authentication
SETUP_USERNAME=admin
SETUP_PASSWORD=change-this-strong-password

# Optional: Railway runtime
PORT=8080
FOXFANG_GATEWAY_PORT=8080
HOME=/data
FOXFANG_HOME=/data/.foxfang

# Optional: provider bootstrap on first run (pick at least one)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
KIMI_API_KEY=
OPENROUTER_API_KEY=

# Optional: force default provider/model in bootstrap
FOXFANG_DEFAULT_PROVIDER=openai
FOXFANG_DEFAULT_MODEL=gpt-4o-mini

# Optional: enable channels at startup
# Example: telegram,discord,slack
FOXFANG_CHANNELS=

# Optional: Signal REST API endpoint (for Signal channel on Railway)
# If you deploy bbernhard/signal-cli-rest-api as service "signal-api":
SIGNAL_HTTP_URL=http://signal-api:8080
